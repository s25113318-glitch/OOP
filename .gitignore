                timeBox.addItem("01:30 PM");
                timeBox.addItem("07:00 PM");


                checkPopcorn.setText("Premium Sea Salt Popcorn (₱180)");
                checkTea.setText("Organic Chamomile Lavender infusion (₱140)");
                checkBites.setText("Gluten-Free Honey Baked Oats (₱160)");
            } else if ("Ayala Malls Cinema Cebu".equals(venue)) {
                filmBox.addItem("Spirited Away: Extended");
                filmBox.addItem("Inside Out 2");
                filmBox.addItem("Godzilla x Kong");


                dateBox.addItem("2026-06-25");
                dateBox.addItem("2026-06-26");


                timeBox.addItem("11:30 AM (Sensory Safe)");
                timeBox.addItem("03:30 PM");


                checkPopcorn.setText("Cebu Sweet Mango Popcorn (₱160)");
                checkTea.setText("Relaxing Peppermint Infusion (₱130)");
                checkBites.setText("Baked Cassava Soft Cakes (₱120)");
            } else if ("Vie Show Taipei Qsquare".equals(venue)) {
                filmBox.addItem("Spirited Away: Extended");
                filmBox.addItem("Crouching Tiger, Hidden Dragon");
                filmBox.addItem("Life of Pi");


                dateBox.addItem("2026-06-15");
                dateBox.addItem("2026-06-18");
                dateBox.addItem("2026-06-20");


                timeBox.addItem("10:30 AM (Sensory Safe)");
                timeBox.addItem("03:00 PM");
                timeBox.addItem("06:30 PM (Sensory Safe)");


                checkPopcorn.setText("Taiwanese Oolong Infused Popcorn (NT$90)");
                checkTea.setText("Warm Steamed Jasmine Tea (NT$80)");
                checkBites.setText("Low-Sugar Soft Sesame Mochi (NT$110)");
            } else if ("Ambassador Theatre Kaohsiung".equals(venue)) {
                filmBox.addItem("Life of Pi");
                filmBox.addItem("Crouching Tiger, Hidden Dragon");
                filmBox.addItem("Interstellar: Re-Release");


                dateBox.addItem("2026-07-01");
                dateBox.addItem("2026-07-02");


                timeBox.addItem("01:00 PM (Sensory Safe)");
                timeBox.addItem("04:30 PM");


                checkPopcorn.setText("Kaohsiung Sea Salted Caramel Corn (NT$95)");
                checkTea.setText("Calming Honey Chrysanthemum Tea (NT$85)");
                checkBites.setText("Steamed Red Bean Paste Cakes (NT$100)");
            } else {
                filmBox.addItem("Dune: Part Three");
                filmBox.addItem("Blade Runner: Re-Echo");
                filmBox.addItem("Inside Out 2");


                dateBox.addItem("2026-07-15");
                dateBox.addItem("2026-07-16");


                timeBox.addItem("02:00 PM (Sensory Safe)");
                timeBox.addItem("06:00 PM");


                checkPopcorn.setText("Organic Sweet Butter Corn (NT$100)");
                checkTea.setText("Calming Lavender Barley Infusion (NT$90)");
                checkBites.setText("Nut-Free Gluten-Free Taro Puff (NT$120)");
            }


            if (Main.SessionManager.selectedMovie != null) {
                String activeTitle = Main.SessionManager.selectedMovie.title;
                for (int i = 0; i < filmBox.getItemCount(); i++) {
                    if (filmBox.getItemAt(i).equalsIgnoreCase(activeTitle)) {
                        filmBox.setSelectedIndex(i);
                        break;
                    }
                }
            }
        }
    }


    // 10. Seating Selection Screen (With Strict Seat Selection Demographics limits)
    public static class SeatSelectionScreen extends JPanel {
        public SeatSelectionScreen(Main app) {
            setLayout(new BorderLayout());
            setOpaque(false);
            setBorder(new EmptyBorder(25, 20, 25, 20));


            JPanel screenPanel = new JPanel() {
                @Override
                protected void paintComponent(Graphics g) {
                    Graphics2D g2 = (Graphics2D) g;
                    g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                    g2.setColor(Main.AppTheme.getSecondaryAccent());
                    g2.setStroke(new BasicStroke(3));
                    g2.draw(new Arc2D.Float(50, 15, getWidth() - 100, 30, 0, 180, Arc2D.OPEN));
                    g2.setFont(Main.AppTheme.getFont(Font.PLAIN, 11));
                    g2.setColor(Color.LIGHT_GRAY);
                    g2.drawString("CINEMA SOUND FIELD FOCUS AREA", getWidth() / 2 - 95, 40);
                }
            };
            screenPanel.setOpaque(false);
            screenPanel.setPreferredSize(new Dimension(400, 50));
            add(screenPanel, BorderLayout.NORTH);


            JPanel grid = new JPanel(new GridLayout(6, 6, 8, 8));
            grid.setOpaque(false);


            for (int i = 1; i <= 36; i++) {
                final String seatId = "S" + i;
                JButton seatBtn = new JButton();
                seatBtn.setPreferredSize(new Dimension(45, 45));
                seatBtn.setOpaque(false);
                seatBtn.setContentAreaFilled(false);
                seatBtn.setFocusPainted(false);
                seatBtn.setBorderPainted(false);


                final boolean isSensoryOptimal = (i % 6 == 1 || i % 6 == 0);


                seatBtn.addActionListener(e -> {
                    if (Main.SessionManager.currentBooking == null) return;


                    int totalBookedCount = Main.SessionManager.currentBooking.adultCount +
                            Main.SessionManager.currentBooking.childCount +
                            Main.SessionManager.currentBooking.pwdCount;


                    if (Main.SessionManager.currentBooking.selectedSeats.contains(seatId)) {
                        Main.SessionManager.currentBooking.selectedSeats.remove(seatId);
                    } else {
                        if (Main.SessionManager.currentBooking.selectedSeats.size() >= totalBookedCount) {
                            JOptionPane.showMessageDialog(this,
                                    "Headcount selection limit reached.\nAs configured on your ticket, you are allocated exactly "
                                            + totalBookedCount + " seat(s).",
                                    "Seating Threshold", JOptionPane.WARNING_MESSAGE);
                            return;
                        }
                        Main.SessionManager.currentBooking.selectedSeats.add(seatId);
                    }
                    repaint();
                });


                seatBtn.setUI(new javax.swing.plaf.basic.BasicButtonUI() {
                    @Override
                    public void paint(Graphics g, JComponent c) {
                        Graphics2D g2 = (Graphics2D) g.create();
                        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                        boolean isSelected = Main.SessionManager.currentBooking != null &&
                                Main.SessionManager.currentBooking.selectedSeats.contains(seatId);


                        Color seatColor;
                        if (isSelected) {
                            seatColor = Main.AppTheme.getAccent();
                        } else if (isSensoryOptimal) {
                            seatColor = Main.AppTheme.getSecondaryAccent();
                        } else {
                            seatColor = new Color(55, 65, 81);
                        }


                        g2.setColor(seatColor);
                        g2.fillRoundRect(2, 2, c.getWidth() - 4, c.getHeight() - 8, 10, 10);
                        g2.setColor(seatColor.darker());
                        g2.fillRoundRect(5, c.getHeight() - 8, c.getWidth() - 10, 6, 4, 4);


                        g2.setColor(Color.WHITE);
                        g2.setFont(Main.AppTheme.getFont(Font.BOLD, 10));
                        g2.drawString(seatId, c.getWidth() / 2 - 8, c.getHeight() / 2 - 2);
                        g2.dispose();
                    }
                });


                grid.add(seatBtn);
            }
            add(grid, BorderLayout.CENTER);


            JPanel controls = new JPanel();
            controls.setLayout(new BoxLayout(controls, BoxLayout.Y_AXIS));
            controls.setOpaque(false);


            JPanel legendPanel = new JPanel();
            legendPanel.setOpaque(false);
            JLabel labelNorm = new JLabel("● Standard"); labelNorm.setForeground(new Color(55, 65, 81));
            JLabel labelSens = new JLabel("● Sensory Optimal"); labelSens.setForeground(Main.AppTheme.getSecondaryAccent());
            JLabel labelSel = new JLabel("● Reserved"); labelSel.setForeground(Main.AppTheme.getAccent());
            legendPanel.add(labelNorm);
            legendPanel.add(Box.createRigidArea(new Dimension(10, 0)));
            legendPanel.add(labelSens);
            legendPanel.add(Box.createRigidArea(new Dimension(10, 0)));
            legendPanel.add(labelSel);


            Main.ModernButton btnConfirm = new Main.ModernButton("COMMIT SELECTION & PAY", Main.AppTheme.getAccent());
            btnConfirm.addActionListener(e -> {
                if (Main.SessionManager.currentBooking == null) return;


                int totalBookedCount = Main.SessionManager.currentBooking.adultCount +
                        Main.SessionManager.currentBooking.childCount +
                        Main.SessionManager.currentBooking.pwdCount;
                int currentSelectionCount = Main.SessionManager.currentBooking.selectedSeats.size();


                if (currentSelectionCount != totalBookedCount) {
                    JOptionPane.showMessageDialog(this,
                            "Headcount mismatch detected!\nPlease select exactly " + totalBookedCount +
                                    " seat(s) to match your ticket demographic booking config (currently chosen: " +
                                    currentSelectionCount + ").",
                            "Incomplete Configuration", JOptionPane.ERROR_MESSAGE);
                } else {
                    if (Main.SessionManager.currentBooking.paymentMethod.toLowerCase().contains("card")) {
                        app.navigateTo("PaymentForm");
                    } else {
                        Main.SessionManager.currentBooking.referenceCode = "LUM-" + (100000 + new Random().nextInt(900000));
                        app.refreshAppLayout();
                        app.navigateTo("Ticket");
                    }
                }
            });


            controls.add(legendPanel);
            controls.add(Box.createRigidArea(new Dimension(0, 15)));
            controls.add(btnConfirm);
            add(controls, BorderLayout.SOUTH);
        }
    }


    // --- NEW SECURE CREDIT CARD GATEWAY SCREEN ---
    public static class PaymentFormScreen extends JPanel {
        public PaymentFormScreen(Main app) {
            setLayout(new GridBagLayout());
            setOpaque(false);
            GridBagConstraints gbc = new GridBagConstraints();
            gbc.gridx = 0; gbc.fill = GridBagConstraints.HORIZONTAL;
            gbc.insets = new Insets(8, 20, 8, 20);


            JLabel title = new JLabel("Secure Card Gateway", JLabel.CENTER);
            title.setFont(Main.AppTheme.getFont(Font.BOLD, 22));
            title.setForeground(Main.AppTheme.getGold());


            Main.MinimalistMovieFrame framePanel = new Main.MinimalistMovieFrame();


            Main.GlassTextField fieldHolder = new Main.GlassTextField(20);
            Main.GlassTextField fieldCardNum = new Main.GlassTextField(20);


            JPanel smallRow = new JPanel(new GridLayout(1, 2, 10, 0));
            smallRow.setOpaque(false);
            Main.GlassTextField fieldExpiry = new Main.GlassTextField(8);
            Main.GlassTextField fieldCVV = new Main.GlassTextField(4);


            JPanel expCol = new JPanel(new BorderLayout()); expCol.setOpaque(false);
            expCol.add(new JLabel("Expiry (MM/YY)"), BorderLayout.NORTH); expCol.add(fieldExpiry, BorderLayout.CENTER);


            JPanel cvvCol = new JPanel(new BorderLayout()); cvvCol.setOpaque(false);
            cvvCol.add(new JLabel("CVV"), BorderLayout.NORTH); cvvCol.add(fieldCVV, BorderLayout.CENTER);


            smallRow.add(expCol);
            smallRow.add(cvvCol);


            Main.ModernButton btnSubmit = new Main.ModernButton("AUTHORIZE & COMPLETE", Main.AppTheme.getAccent());
            Main.ModernButton btnBack = new Main.ModernButton("CANCEL TRANSACTION", Main.AppTheme.getSurfaceGlass());


            btnSubmit.addActionListener(e -> {
                String name = fieldHolder.getText().trim();
                String card = fieldCardNum.getText().trim().replaceAll("\\s", "");
                String exp = fieldExpiry.getText().trim();
                String cvv = fieldCVV.getText().trim();


                if (name.isEmpty() || card.isEmpty() || exp.isEmpty() || cvv.isEmpty()) {
                    JOptionPane.showMessageDialog(this, "Complete all marked components.");
                } else if (!card.matches("\\d{16}")) {
                    JOptionPane.showMessageDialog(this, "Please enter a valid 16-digit card number.");
                } else if (!exp.matches("^(0[1-9]|1[0-2])\\/?([0-9]{2})$")) {
                    JOptionPane.showMessageDialog(this, "Please enter a valid expiry format (MM/YY).");
                } else if (!cvv.matches("\\d{3}")) {
                    JOptionPane.showMessageDialog(this, "Please enter a valid 3-digit CVV code.");
                } else {
                    if (Main.SessionManager.currentBooking != null) {
                        Main.SessionManager.currentBooking.referenceCode = "LUM-" + (100000 + new Random().nextInt(900000));
                    }
                    app.refreshAppLayout();
                    app.navigateTo("Ticket");
                }
            });


            btnBack.addActionListener(e -> app.navigateTo("Seats"));


            gbc.gridy = 0; add(title, gbc);
            gbc.gridy = 1; add(framePanel, gbc);
            gbc.gridy = 2; add(new JLabel("Cardholder Full Name"), gbc);
            gbc.gridy = 3; add(fieldHolder, gbc);
            gbc.gridy = 4; add(new JLabel("Card Number (16 Digits)"), gbc);
            gbc.gridy = 5; add(fieldCardNum, gbc);
            gbc.gridy = 6; add(smallRow, gbc);
            gbc.gridy = 7; add(Box.createRigidArea(new Dimension(0, 15)), gbc);
            gbc.gridy = 8; add(btnSubmit, gbc);
            gbc.gridy = 9; add(btnBack, gbc);
        }
    }


    // --- CUSTOM VISUAL RECEIPT CANVAS DRAWING PANEL ---
    public static class CreativeReceiptPanel extends JPanel {
        public CreativeReceiptPanel() {
            setOpaque(false);
            setPreferredSize(new Dimension(420, 520));
        }


        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2 = (Graphics2D) g.create();
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);


            Main.Booking b = Main.SessionManager.currentBooking;
            Main.User u = Main.SessionManager.currentUser;
            if (b == null || u == null) {
                g2.dispose();
                return;
            }


            int w = getWidth();
            int h = getHeight();


            int slipW = 340;
            int slipH = 460;
            int rx = (w - slipW) / 2;
            int ry = (h - slipH) / 2;


            g2.setColor(new Color(0, 0, 0, 120));
            g2.fillRoundRect(rx + 4, ry + 4, slipW, slipH, 16, 16);


            g2.setColor(new Color(248, 250, 252));
            g2.fillRoundRect(rx, ry, slipW, slipH, 16, 16);


            g2.setColor(new Color(15, 23, 42));
            g2.fillRoundRect(rx, ry, slipW, 45, 16, 16);
            g2.fillRect(rx, ry + 30, slipW, 15);


            g2.setColor(Color.WHITE);
            g2.setFont(new Font("SansSerif", Font.BOLD, 14));
            g2.drawString("LUMINA SENSORY RECEIPT", rx + 24, ry + 28);


            g2.setColor(new Color(30, 41, 59));
            int drawY = ry + 75;


            g2.setFont(new Font("Monospaced", Font.BOLD, 12));
            g2.drawString("BILL TO: " + u.fullName, rx + 20, drawY);
            drawY += 18;
            g2.drawString("EMAIL: " + u.email, rx + 20, drawY);
            drawY += 18;
            g2.drawString("REF CODE: " + b.referenceCode, rx + 20, drawY);
            drawY += 20;


            g2.setColor(Color.LIGHT_GRAY);
            g2.setStroke(new BasicStroke(1.0f, BasicStroke.CAP_BUTT, BasicStroke.JOIN_MITER, 10.0f, new float[]{4, 4}, 0.0f));
            g2.drawLine(rx + 20, drawY, rx + slipW - 20, drawY);
            drawY += 20;


            g2.setColor(new Color(51, 65, 85));
            g2.setFont(new Font("SansSerif", Font.PLAIN, 11));


            String sym = b.movie.getCurrencySymbol(u.country);
            double baseRate = b.movie.getPriceInCurrency(u.country);


            g2.drawString("Adult Seats (" + b.adultCount + "x)", rx + 20, drawY);
            g2.drawString(sym + String.format("%.2f", b.adultCount * baseRate), rx + slipW - 100, drawY);
            drawY += 18;


            if (b.childCount > 0) {
                g2.drawString("Child Seats (-30%) (" + b.childCount + "x)", rx + 20, drawY);
                g2.drawString(sym + String.format("%.2f", b.childCount * (baseRate * 0.7)), rx + slipW - 100, drawY);
                drawY += 18;
            }


            if (b.pwdCount > 0) {
                g2.drawString("PWD Seats (-40%) (" + b.pwdCount + "x)", rx + 20, drawY);
                g2.drawString(sym + String.format("%.2f", b.pwdCount * (baseRate * 0.6)), rx + slipW - 100, drawY);
                drawY += 18;
            }


            String foodStr = b.foodPopcorn || b.foodChamomileTea || b.foodCalmBites ? "Applied" : "None";
            g2.drawString("Sensory Concessions:", rx + 20, drawY);
            g2.drawString(foodStr, rx + slipW - 100, drawY);
            drawY += 20;


            g2.drawLine(rx + 20, drawY, rx + slipW - 20, drawY);
            drawY += 25;


            g2.setFont(new Font("SansSerif", Font.BOLD, 15));
            g2.setColor(new Color(15, 23, 42));
            g2.drawString("TOTAL PAID:", rx + 20, drawY);
            g2.setColor(new Color(255, 0, 120));
            g2.drawString(sym + String.format("%.2f", b.calculatedPrice), rx + slipW - 130, drawY);
            drawY += 25;


            g2.setFont(new Font("SansSerif", Font.ITALIC, 10));
            g2.setColor(Color.GRAY);
            g2.drawString("Processor Gateway: " + b.paymentMethod, rx + 20, drawY);
            drawY += 15;
            g2.drawString("Lumina Hub Transaction ID secured.", rx + 20, drawY);


            g2.rotate(Math.toRadians(-12), rx + 220, drawY + 30);
            g2.setColor(new Color(0, 180, 100, 180));
            g2.setStroke(new BasicStroke(2.0f));
            g2.drawRoundRect(rx + 155, drawY + 10, 85, 30, 8, 8);
            g2.setFont(new Font("SansSerif", Font.BOLD, 14));
            g2.drawString("PAID & OK", rx + 165, drawY + 30);


            g2.dispose();
        }
    }


    // --- CUSTOM VISUAL ADMISSION TICKET DRAWING PANEL ---
    public static class CreativeTicketPanel extends JPanel {
        public CreativeTicketPanel() {
            setOpaque(false);
            setPreferredSize(new Dimension(420, 520));
        }


        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2 = (Graphics2D) g.create();
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);


            Main.Booking b = Main.SessionManager.currentBooking;
            Main.User u = Main.SessionManager.currentUser;
            if (b == null || u == null) {
                g2.dispose();
                return;
            }


            int w = getWidth();
            int h = getHeight();


            int slipW = 340;
            int slipH = 460;
            int rx = (w - slipW) / 2;
            int ry = (h - slipH) / 2;


            g2.setColor(new Color(0, 0, 0, 140));
            g2.fillRoundRect(rx + 4, ry + 4, slipW, slipH, 20, 20);


            g2.setColor(new Color(15, 23, 42));
            g2.fillRoundRect(rx, ry, slipW, slipH, 20, 20);


            g2.setColor(Main.AppTheme.getAccent());
            g2.setStroke(new BasicStroke(2.0f));
            g2.drawRoundRect(rx, ry, slipW, slipH, 20, 20);


            g2.setColor(Main.AppTheme.getBackgroundEnd());
            g2.fillOval(rx - 15, ry + 180, 30, 30);
            g2.fillOval(rx + slipW - 15, ry + 180, 30, 30);


            g2.setColor(new Color(255, 255, 255, 80));
            g2.setStroke(new BasicStroke(1.5f, BasicStroke.CAP_BUTT, BasicStroke.JOIN_BEVEL, 0, new float[]{6, 6}, 0));
            g2.drawLine(rx + 20, ry + 195, rx + slipW - 20, ry + 195);


            g2.setColor(Color.WHITE);
            g2.setFont(Main.AppTheme.getFont(Font.BOLD, 15));
            g2.drawString("LUMINA ADMISSION TICKET", rx + 24, ry + 38);


            g2.setFont(Main.AppTheme.getFont(Font.PLAIN, 10));
            g2.setColor(Main.AppTheme.getSecondaryAccent());
            g2.drawString("Sensory safe movie admission access pass.", rx + 24, ry + 54);


            g2.setColor(Color.LIGHT_GRAY);
            g2.setFont(new Font("SansSerif", Font.PLAIN, 11));
            int drawY = ry + 85;


            g2.drawString("OWNER:", rx + 24, drawY);
            g2.setColor(Color.WHITE);
            g2.drawString(u.fullName, rx + 120, drawY);
            drawY += 20;


            g2.setColor(Color.LIGHT_GRAY);
            g2.drawString("FILM:", rx + 24, drawY);
            g2.setColor(Main.AppTheme.getGold());
            g2.drawString(b.movie.title, rx + 120, drawY);
            drawY += 20;


            g2.setColor(Color.LIGHT_GRAY);
            g2.drawString("VENUE:", rx + 24, drawY);
            g2.setColor(Color.WHITE);
            g2.drawString(b.selectedVenue, rx + 120, drawY);
            drawY += 20;


            g2.setColor(Color.LIGHT_GRAY);
            g2.drawString("SCHEDULE:", rx + 24, drawY);
            g2.setColor(Color.WHITE);
            g2.drawString(b.selectedDate + " @ " + b.selectedTime, rx + 120, drawY);
            drawY += 20;


            g2.setColor(Color.LIGHT_GRAY);
            g2.drawString("SEATS:", rx + 24, drawY);
            g2.setColor(Main.AppTheme.getSecondaryAccent());
            g2.drawString(b.selectedSeats.toString(), rx + 120, drawY);


            int qrSize = 130;
            int qrx = rx + (slipW - qrSize) / 2;
            int qry = ry + 225;


            Main.QRGenerator.drawMatrix(g2, qrx, qry, qrSize, b.referenceCode);


            g2.setColor(Color.GRAY);
            g2.setFont(new Font("Monospaced", Font.BOLD, 11));
            g2.drawString("SERIAL: " + b.referenceCode, rx + 105, ry + slipH - 30);


            g2.dispose();
        }
    }


    // 11. Custom Divided Boarding Pass Receipt Screen
    public static class TicketScreen extends JPanel {
        private final JPanel cardContainer = new JPanel(new CardLayout());
        private final CardLayout cards = (CardLayout) cardContainer.getLayout();
        private final Main.ModernButton btnTabTicket = new Main.ModernButton("ADMISSION TICKET", Main.AppTheme.getAccent());
        private final Main.ModernButton btnTabReceipt = new Main.ModernButton("PAYMENT RECEIPT", Main.AppTheme.getSurfaceGlass());


        public TicketScreen(Main app) {
            setLayout(new BorderLayout());
            setOpaque(false);
            setBorder(new EmptyBorder(15, 20, 15, 20));


            JPanel tabHeader = new JPanel(new GridLayout(1, 2, 10, 0));
            tabHeader.setOpaque(false);
            tabHeader.setPreferredSize(new Dimension(440, 42));


            btnTabTicket.addActionListener(e -> {
                btnTabTicket.setBackground(Main.AppTheme.getAccent());
                btnTabReceipt.setBackground(Main.AppTheme.getSurfaceGlass());
                cards.show(cardContainer, "TICKET");
            });


            btnTabReceipt.addActionListener(e -> {
                btnTabReceipt.setBackground(Main.AppTheme.getAccent());
                btnTabTicket.setBackground(Main.AppTheme.getSurfaceGlass());
                cards.show(cardContainer, "RECEIPT");
            });


            tabHeader.add(btnTabTicket);
            tabHeader.add(btnTabReceipt);
            add(tabHeader, BorderLayout.NORTH);


            cardContainer.setOpaque(false);
            cardContainer.add(new Main.CreativeTicketPanel(), "TICKET");
            cardContainer.add(new Main.CreativeReceiptPanel(), "RECEIPT");
            add(cardContainer, BorderLayout.CENTER);


            Main.ModernButton btnFinish = new Main.ModernButton("COMPLETE RESERVATION", Main.AppTheme.getAccent());
            btnFinish.addActionListener(e -> {
                Main.User u = Main.SessionManager.currentUser;
                Main.Booking b = Main.SessionManager.currentBooking;
                if (b != null && u != null) {
                    b.userEmail = u.email;
                    Main.SessionManager.pastBookings.add(b);


                    Frame parentFrame = (Frame) SwingUtilities.getWindowAncestor(this);
                    Main.DispatchQRDialog qrDialog = new Main.DispatchQRDialog(parentFrame, u.email, b.referenceCode);
                    qrDialog.setVisible(true);
                }
                Main.SessionManager.currentBooking = null;
                app.navigateTo("Dashboard");
            });
            add(btnFinish, BorderLayout.SOUTH);
        }
    }


    // --- BOTTOM GLOBAL NAVIGATION BAR ---
    private static JPanel createBottomNavigation(Main app) {
        JPanel nav = new JPanel(new GridLayout(1, 5));
        nav.setBackground(new Color(15, 23, 42));
        nav.setPreferredSize(new Dimension(480, 60));


        String[] labels = {
                Main.Dictionary.get("nav_dashboard"),
                Main.Dictionary.get("nav_library"),
                Main.Dictionary.get("nav_about"),
                Main.Dictionary.get("nav_profile"),
                Main.Dictionary.get("nav_logout")
        };


        for (String label : labels) {
            JButton btn = new JButton(label);
            btn.setForeground(Color.WHITE);
            btn.setFont(Main.AppTheme.getFont(Font.BOLD, 10));
            btn.setContentAreaFilled(false);
            btn.setBorderPainted(false);
            btn.setFocusPainted(false);


            btn.addActionListener(e -> {
                if (label.equals(Main.Dictionary.get("nav_logout"))) {
                    Main.SessionManager.currentUser = null;
                    app.navigateTo("Entrance");
                } else if (label.equals(Main.Dictionary.get("nav_dashboard"))) {
                    app.navigateTo("Dashboard");
                } else if (label.equals(Main.Dictionary.get("nav_library"))) {
                    app.navigateTo("Library");
                } else if (label.equals(Main.Dictionary.get("nav_about"))) {
                    app.navigateTo("AboutLumina");
                } else if (label.equals(Main.Dictionary.get("nav_profile"))) {
                    app.navigateTo("UserProfile");
                }
            });
            nav.add(btn);
        }
        return nav;
    }


    public static void main(String[] args) {
        SwingUtilities.invokeLater(Main::new);
    }
}

