    // --- SYSTEM THEMING CONTROLLER ---
    public static class AppTheme {
        public static boolean sensorySafeMode = false;
        public static boolean dyslexiaFontMode = false;


        public static Color getBackgroundStart() {
            return sensorySafeMode ? new Color(34, 40, 49) : new Color(11, 15, 26);
        }


        public static Color getBackgroundEnd() {
            return sensorySafeMode ? new Color(20, 24, 30) : new Color(2, 4, 8);
        }


        public static Color getAccent() {
            return sensorySafeMode ? new Color(147, 131, 230) : new Color(255, 0, 120);
        }


        public static Color getSecondaryAccent() {
            return sensorySafeMode ? new Color(110, 160, 210) : new Color(0, 229, 255);
        }


        public static Color getGold() {
            return sensorySafeMode ? new Color(230, 190, 110) : new Color(255, 191, 0);
        }


        public static Color getSurfaceGlass() {
            return sensorySafeMode ? new Color(255, 255, 255, 30) : new Color(255, 255, 255, 12);
        }


        public static Color getBorderGlass() {
            return sensorySafeMode ? new Color(255, 255, 255, 60) : new Color(255, 255, 255, 25);
        }


        public static Color getTextColor() {
            return Color.WHITE;
        }


        public static Font getFont(int style, int size) {
            String fontName = dyslexiaFontMode ? "Monospaced" : (sensorySafeMode ? "Monospaced" : "SansSerif");
            return new Font(fontName, style, size);
        }
    }


    // --- IMAGE LOADING & SMOOTH SCALING UTILITY ---
    public static ImageIcon getScaledImage(String path, int width, int height) {
        try {
            java.net.URL imgUrl = Main.class.getResource("/" + path);
            Image img;
            if (imgUrl != null) {
                img = new ImageIcon(imgUrl).getImage();
            } else {
                img = new ImageIcon(path).getImage();
            }
            if (img.getWidth(null) == -1) {
                return null;
            }
            return new ImageIcon(img.getScaledInstance(width, height, Image.SCALE_SMOOTH));
        } catch (Exception e) {
            return null;
        }
    }


    // --- PROGRAMMATIC QR CODE GENERATOR ---
    public static class QRGenerator {
        public static void drawFinderPattern(Graphics2D g2, int x, int y, int size) {
            g2.setColor(Color.WHITE);
            g2.fillRect(x, y, size, size);
            g2.setColor(new Color(15, 23, 42));
            g2.fillRect(x + size / 7, y + size / 7, size - 2 * (size / 7), size - 2 * (size / 7));
            g2.setColor(Color.WHITE);
            g2.fillRect(x + 2 * (size / 7), y + 2 * (size / 7), size - 4 * (size / 7), size - 4 * (size / 7));
        }


        public static void drawMatrix(Graphics2D g2, int x, int y, int size, String refCode) {
            g2.setColor(Color.WHITE);
            g2.fillRect(x, y, size, size);


            int modules = 21;
            int cellSize = size / modules;
            int finderSize = 7 * cellSize;


            drawFinderPattern(g2, x, y, finderSize);
            drawFinderPattern(g2, x + size - finderSize, y, finderSize);
            drawFinderPattern(g2, x, y + size - finderSize, finderSize);


            Random rand = new Random(refCode.hashCode());
            g2.setColor(new Color(15, 23, 42));
            for (int r = 0; r < modules; r++) {
                for (int c = 0; c < modules; c++) {
                    if ((r < 7 && c < 7) || (r < 7 && c >= modules - 7) || (r >= modules - 7 && c < 7)) {
                        continue;
                    }
                    if (rand.nextBoolean()) {
                        g2.fillRect(x + c * cellSize, y + r * cellSize, cellSize, cellSize);
                    }
                }
            }
        }
    }


    // --- CUSTOM VISUAL CONTAINER RENDERING SCHEMES ---


    public static class GradientBackgroundPanel extends JPanel {
        public GradientBackgroundPanel(JPanel content) {
            setLayout(new BorderLayout());
            setOpaque(false);
            add(content, BorderLayout.CENTER);
        }


        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2 = (Graphics2D) g.create();
            g2.setRenderingHint(RenderingHints.KEY_RENDERING, RenderingHints.VALUE_RENDER_QUALITY);
            GradientPaint gp = new GradientPaint(0, 0, Main.AppTheme.getBackgroundStart(), 0, getHeight(), Main.AppTheme.getBackgroundEnd());
            g2.setPaint(gp);
            g2.fillRect(0, 0, getWidth(), getHeight());
            g2.dispose();
        }
    }


    public static class GlassPanel extends JPanel {
        public GlassPanel() {
            setOpaque(false);
            setBorder(new EmptyBorder(14, 14, 14, 14));
        }


        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2 = (Graphics2D) g.create();
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
            g2.setColor(new Color(20, 26, 41));
            g2.fillRoundRect(0, 0, getWidth() - 1, getHeight() - 1, 24, 24);
            g2.setColor(Main.AppTheme.getBorderGlass());
            g2.setStroke(new BasicStroke(1.2f));
            g2.drawRoundRect(0, 0, getWidth() - 1, getHeight() - 1, 24, 24);
            g2.dispose();
        }
    }


    public static class PulsingGlassPanel extends GlassPanel {
        private float pulseAlpha = 0.4f;
        private boolean increasing = true;
        private final javax.swing.Timer pulseTimer;


        public PulsingGlassPanel() {
            super();
            pulseTimer = new javax.swing.Timer(40, e -> {
                if (!isShowing()) return;
                if (increasing) {
                    pulseAlpha += 0.015f;
                    if (pulseAlpha >= 0.85f) increasing = false;
                } else {
                    pulseAlpha -= 0.015f;
                    if (pulseAlpha <= 0.4f) increasing = true;
                }
                repaint();
            });
            pulseTimer.start();
        }


        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2 = (Graphics2D) g.create();
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);


            Color baseBg = Main.AppTheme.getBackgroundStart();
            Color glowBg = new Color(
                    baseBg.getRed(),
                    baseBg.getGreen(),
                    baseBg.getBlue(),
                    (int) (35 + (20 * pulseAlpha))
            );
            g2.setColor(glowBg);
            g2.fillRoundRect(0, 0, getWidth() - 1, getHeight() - 1, 24, 24);


            Color borderGlow = Main.AppTheme.getSecondaryAccent();
            Color glowingBorder = new Color(
                    borderGlow.getRed(),
                    borderGlow.getGreen(),
                    borderGlow.getBlue(),
                    (int) (40 + (120 * pulseAlpha))
            );
            g2.setColor(glowingBorder);
            g2.setStroke(new BasicStroke(1.5f));
            g2.drawRoundRect(0, 0, getWidth() - 1, getHeight() - 1, 24, 24);
            g2.dispose();
        }
    }


    public static class ModernButton extends JButton {
        private final Color baseColor;
        private boolean isHovered = false;


        public ModernButton(String text, Color bg) {
            super(text);
            this.baseColor = bg;
            setOpaque(false);
            setContentAreaFilled(false);
            setBorderPainted(false);
            setFocusPainted(false);
            setForeground(Color.WHITE);
            setFont(Main.AppTheme.getFont(Font.BOLD, 13));
            setPreferredSize(new Dimension(340, 50));


            addMouseListener(new MouseAdapter() {
                @Override public void mouseEntered(MouseEvent e) { isHovered = true; repaint(); }
                @Override public void mouseExited(MouseEvent e) { isHovered = false; repaint(); }
            });
        }


        @Override
        protected void paintComponent(Graphics g) {
            Graphics2D g2 = (Graphics2D) g.create();
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
            Color drawColor = isHovered ? baseColor.brighter() : baseColor;
            g2.setColor(drawColor);
            g2.fill(new RoundRectangle2D.Float(0, 0, getWidth(), getHeight(), 22, 22));
            g2.dispose();
            super.paintComponent(g);
        }
    }


    public static class GlassTextField extends JTextField {
        public GlassTextField(int columns) {
            super(columns);
            setOpaque(false);
            setForeground(Main.AppTheme.getTextColor());
            setCaretColor(Main.AppTheme.getAccent());
            setFont(Main.AppTheme.getFont(Font.PLAIN, 14));
            setBorder(BorderFactory.createCompoundBorder(
                    new RoundBorder(Main.AppTheme.getBorderGlass(), 12),
                    new EmptyBorder(8, 12, 8, 12)
            ));
            setBackground(new Color(255, 255, 255, 6));
        }


        public static class RoundBorder extends AbstractBorder {
            private final Color color;
            private final int radius;


            public RoundBorder(Color color, int radius) {
                this.color = color;
                this.radius = radius;
            }


            @Override
            public void paintBorder(Component c, Graphics g, int x, int y, int width, int height) {
                Graphics2D g2 = (Graphics2D) g.create();
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(color);
                g2.drawRoundRect(x, y, width - 1, height - 1, radius, radius);
                g2.dispose();
            }
        }
    }


    // --- CUSTOM EMAIL DISPATCH QR DIALOG POP-UP ---
    public static class DispatchQRDialog extends JDialog {
        public DispatchQRDialog(Frame parent, String email, String refCode) {
            super(parent, "Lumina Auto Dispatch", true);
            setSize(340, 410);
            setLocationRelativeTo(parent);
            setResizable(false);


            JPanel root = new JPanel();
            root.setLayout(new BoxLayout(root, BoxLayout.Y_AXIS));
            root.setBackground(new Color(11, 15, 26));
            root.setBorder(new EmptyBorder(25, 20, 20, 20));


            JLabel title = new JLabel("Email Dispatch Sent!", JLabel.CENTER);
            title.setFont(Main.AppTheme.getFont(Font.BOLD, 18));
            title.setForeground(Main.AppTheme.getAccent());
            title.setAlignmentX(Component.CENTER_ALIGNMENT);


            JLabel body = new JLabel("<html><center>An official sensory ticket confirmation was successfully routed to <b>" + email + "</b></center></html>", JLabel.CENTER);
            body.setFont(Main.AppTheme.getFont(Font.PLAIN, 12));
            body.setForeground(Color.LIGHT_GRAY);
            body.setAlignmentX(Component.CENTER_ALIGNMENT);
            body.setMaximumSize(new Dimension(280, 50));


            JPanel qrWrapper = new JPanel() {
                @Override
                protected void paintComponent(Graphics g) {
                    super.paintComponent(g);
                    Main.QRGenerator.drawMatrix((Graphics2D) g, 10, 10, 130, refCode);
                }
            };
            qrWrapper.setPreferredSize(new Dimension(150, 150));
            qrWrapper.setMaximumSize(new Dimension(150, 150));
            qrWrapper.setOpaque(false);
            qrWrapper.setAlignmentX(Component.CENTER_ALIGNMENT);


            JLabel codeLbl = new JLabel("SCAN KIOSK CODE: " + refCode, JLabel.CENTER);
            codeLbl.setFont(Main.AppTheme.getFont(Font.BOLD, 12));
            codeLbl.setForeground(Main.AppTheme.getGold());
            codeLbl.setAlignmentX(Component.CENTER_ALIGNMENT);


            Main.ModernButton btnDismiss = new Main.ModernButton("COMPLETE SESSION", Main.AppTheme.getAccent());
            btnDismiss.setPreferredSize(new Dimension(280, 40));
            btnDismiss.setAlignmentX(Component.CENTER_ALIGNMENT);
            btnDismiss.addActionListener(e -> dispose());


            root.add(title);
            root.add(Box.createRigidArea(new Dimension(0, 12)));
            root.add(body);
            root.add(Box.createRigidArea(new Dimension(0, 15)));
            root.add(qrWrapper);
            root.add(Box.createRigidArea(new Dimension(0, 12)));
            root.add(codeLbl);
            root.add(Box.createRigidArea(new Dimension(0, 20)));
            root.add(btnDismiss);


            setContentPane(root);
        }
    }


    // --- COMPONENT VECTOR ART (PRISM LOGO & FLAGS) ---
    public static class LuminaLogoPanel extends JPanel {
        private double rotateAngle = 0;


        public LuminaLogoPanel() {
            setPreferredSize(new Dimension(140, 140));
            setOpaque(false);
            javax.swing.Timer timer = new javax.swing.Timer(40, e -> {
                rotateAngle += 1.5;
                repaint();
            });
            timer.start();
        }


        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2 = (Graphics2D) g.create();
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
            int cx = getWidth() / 2;
            int cy = getHeight() / 2;


            g2.rotate(Math.toRadians(rotateAngle), cx, cy);
            float[] dists = {0.1f, 0.9f};
            Color[] colors = {Main.AppTheme.getAccent(), new Color(0, 0, 0, 0)};
            RadialGradientPaint rgb = new RadialGradientPaint(cx, cy, 65, dists, colors);
            g2.setPaint(rgb);
            g2.fillOval(cx - 65, cy - 65, 130, 130);


            g2.rotate(Math.toRadians(-rotateAngle * 2), cx, cy);
            g2.setColor(Main.AppTheme.getSecondaryAccent());
            g2.setStroke(new BasicStroke(2f));
            g2.drawLine(cx, cy, cx - 40, cy + 40);
            g2.setColor(Main.AppTheme.getAccent());
            g2.drawLine(cx, cy, cx + 40, cy + 40);


            Path2D.Float prism = new Path2D.Float();
            prism.moveTo(cx, cy - 28);
            prism.lineTo(cx + 25, cy + 20);
            prism.lineTo(cx - 25, cy + 20);
            prism.closePath();


            g2.setPaint(new GradientPaint(cx, cy - 28, Color.WHITE, cx, cy + 20, new Color(255, 255, 255, 50)));
            g2.fill(prism);
            g2.setColor(Main.AppTheme.getGold());
            g2.setStroke(new BasicStroke(2.5f));
            g2.draw(prism);


            g2.dispose();
        }
    }


    public static class ProgrammaticFlag {
        public static void drawPhilippines(Graphics2D g2, int w, int h) {
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
            g2.setColor(Color.WHITE);
            g2.fillRect(0, 0, w, h);


            g2.setColor(new Color(0, 56, 168));
            g2.fillRect(0, 0, w, h / 2);


            g2.setColor(new Color(206, 17, 38));
            g2.fillRect(0, h / 2, w, h / 2);


            Path2D.Float triangle = new Path2D.Float();
            triangle.moveTo(0, 0);
            triangle.lineTo(w / 2.2f, h / 2f);
            triangle.lineTo(0, h);
            triangle.closePath();
            g2.setColor(Color.WHITE);
            g2.fill(triangle);


            g2.setColor(new Color(242, 193, 46));
            int sx = w / 7;
            int sy = h / 2;
            g2.fillOval(sx - 4, sy - 4, 8, 8);


            g2.setStroke(new BasicStroke(1));
            for (int i = 0; i < 8; i++) {
                double angle = Math.toRadians(i * 45);
                g2.drawLine(sx, sy, (int)(sx + 6 * Math.cos(angle)), (int)(sy + 6 * Math.sin(angle)));
            }


            g2.setColor(new Color(242, 193, 46));
            g2.fillRect(w / 18, h / 4, 2, 2);
            g2.fillRect(w / 18, 3 * h / 4, 2, 2);
            g2.fillRect(w / 3, h / 2, 2, 2);
        }


        public static void drawTaiwan(Graphics2D g2, int w, int h) {
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);


            g2.setColor(new Color(254, 0, 0));
            g2.fillRect(0, 0, w, h);


            g2.setColor(new Color(0, 0, 149));
            g2.fillRect(0, 0, w / 2, h / 2);


            g2.setColor(Color.WHITE);
            int cx = w / 4;
            int cy = h / 4;
            g2.fillOval(cx - 3, cy - 3, 6, 6);


            g2.setStroke(new BasicStroke(1.2f));
            for (int i = 0; i < 12; i++) {
                double angle = Math.toRadians(i * 30);
                g2.drawLine(cx, cy, (int)(cx + 6 * Math.cos(angle)), (int)(cy + 6 * Math.sin(angle)));
            }
        }
    }


    public static class FlagCanvas extends JPanel {
        private final boolean isPhilippines;


        public FlagCanvas(boolean isPH) {
            this.isPhilippines = isPH;
            setPreferredSize(new Dimension(32, 20));
            setOpaque(false);
        }


        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2 = (Graphics2D) g.create();
            if (isPhilippines) {
                Main.ProgrammaticFlag.drawPhilippines(g2, getWidth(), getHeight());
            } else {
                Main.ProgrammaticFlag.drawTaiwan(g2, getWidth(), getHeight());
            }
            g2.setColor(Main.AppTheme.getBorderGlass());
            g2.drawRect(0, 0, getWidth() - 1, getHeight() - 1);
            g2.dispose();
        }
    }


    // --- REAL MOVIE PORTRAIT ART / IMAGE POSTER CANVAS ---
    public static class PosterCanvas extends JPanel {
        private final String movieTitle;


        public PosterCanvas(String title) {
            this.movieTitle = title;
            setPreferredSize(new Dimension(55, 80));
            setOpaque(false);
        }


        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2 = (Graphics2D) g.create();
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);


            String cleanName = movieTitle.toLowerCase()
                    .replaceAll(":", "")
                    .replaceAll("&", "and")
                    .replaceAll("[^a-z0-9]", "_")
                    .replaceAll("__+", "_");
            String filePath = "images/" + cleanName + ".jpg";


            ImageIcon scaledIcon = Main.getScaledImage(filePath, getWidth(), getHeight());


            if (scaledIcon != null) {
                g2.drawImage(scaledIcon.getImage(), 0, 0, this);
                g2.setColor(Main.AppTheme.getBorderGlass());
                g2.drawRoundRect(0, 0, getWidth() - 1, getHeight() - 1, 14, 14);
            } else {
                Main.PosterArt.paint(g2, getWidth(), getHeight(), movieTitle);
            }
            g2.dispose();
        }
    }


    public static class PosterArt {
        public static void paint(Graphics2D g2, int w, int h, String title) {
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);


            g2.setColor(new Color(15, 20, 30));
            g2.fillRoundRect(0, 0, w, h, 14, 14);


            if (title.toLowerCase().contains("godzilla")) {
                g2.setPaint(new GradientPaint(0, 0, new Color(255, 0, 128), w, h, new Color(255, 90, 0)));
                g2.fillOval(w/2 - 20, h/2 - 20, 40, 40);
                g2.setColor(Color.BLACK);
                g2.fillRect(0, h - 25, w, 25);
                g2.setColor(new Color(255, 255, 255, 120));
                g2.setStroke(new BasicStroke(1.5f));
                g2.drawOval(w/2 - 20, h/2 - 20, 40, 40);
            } else if (title.toLowerCase().contains("inside out")) {
                g2.setColor(new Color(0, 229, 255, 200)); g2.fillOval(10, 15, 20, 20);
                g2.setColor(new Color(255, 191, 0, 200)); g2.fillOval(28, 12, 16, 16);
                g2.setColor(new Color(150, 0, 255, 200)); g2.fillOval(18, 35, 22, 22);
                g2.setColor(new Color(255, 40, 40, 150)); g2.fillOval(26, 40, 14, 14);
            } else if (title.toLowerCase().contains("dune")) {
                g2.setPaint(new GradientPaint(0, 0, new Color(218, 145, 0), 0, h, new Color(110, 50, 10)));
                g2.fillRect(0, 0, w, h);
                g2.setColor(new Color(255, 255, 220));
                g2.fillOval(w - 20, 12, 10, 10);
                g2.fillOval(w - 32, 20, 5, 5);
                g2.setColor(Color.BLACK);
                g2.setStroke(new BasicStroke(2));
                g2.drawArc(-15, h - 30, w + 30, 40, 0, 180);
            } else if (title.toLowerCase().contains("deadpool")) {
                g2.setColor(new Color(160, 10, 20));
                g2.fillRoundRect(4, 4, w/2 - 4, h - 8, 8, 8);
                g2.setColor(new Color(210, 160, 10));
                g2.fillRoundRect(w/2, 4, w/2 - 4, h - 8, 8, 8);
                g2.setColor(Color.BLACK);
                g2.fillOval(w/2 - 12, h/2 - 10, 10, 16);
                g2.fillOval(w/2 + 2, h/2 - 10, 10, 16);
            } else if (title.toLowerCase().contains("spirited away")) {
                g2.setPaint(new GradientPaint(0, 0, new Color(75, 0, 130), 0, h, new Color(139, 0, 0)));
                g2.fillRect(0, 0, w, h);
                g2.setColor(new Color(255, 215, 0));
                g2.fillOval(10, 12, 8, 8);
                g2.setColor(Color.BLACK);
                g2.fillRect(0, h - 18, w, 18);
            } else if (title.toLowerCase().contains("interstellar")) {
                g2.setColor(Color.BLACK);
                g2.fillRect(0, 0, w, h);
                g2.setPaint(new GradientPaint(0, h/2, new Color(255, 191, 0, 240), w, h/2, new Color(255, 120, 0, 50)));
                g2.setStroke(new BasicStroke(4));
                g2.drawArc(-10, h/2 - 12, w + 20, 24, 0, 180);
                g2.setColor(Color.BLACK);
                g2.fillOval(w/2 - 6, h/2 - 6, 12, 12);
            } else if (title.toLowerCase().contains("crouching tiger") || title.toLowerCase().contains("hidden dragon")) {
                g2.setColor(new Color(245, 240, 225));
                g2.fillRect(0, 0, w, h);
                g2.setColor(new Color(40, 40, 40));
                g2.setStroke(new BasicStroke(3f, BasicStroke.CAP_ROUND, BasicStroke.JOIN_ROUND));
                g2.draw(new CubicCurve2D.Float(10, 10, w/3, h-20, 2*w/3, 20, w-10, h-10));
                g2.setColor(new Color(180, 10, 20));
                g2.fillRect(w - 15, h - 20, 8, 12);
            } else if (title.toLowerCase().contains("manila") || title.toLowerCase().contains("claws of light")) {
                g2.setPaint(new GradientPaint(0, 0, new Color(230, 90, 10), 0, h, new Color(50, 10, 10)));
                g2.fillRect(0, 0, w, h);
                g2.setColor(new Color(255, 215, 0, 180));
                g2.fillOval(w/2 - 16, 20, 32, 32);
                g2.setColor(Color.BLACK);
                g2.fillRect(5, h - 35, 12, 35);
                g2.fillRect(20, h - 25, 15, 25);
                g2.fillRect(38, h - 40, 12, 40);
            } else if (title.toLowerCase().contains("life of pi")) {
                g2.setPaint(new GradientPaint(0, 0, new Color(0, 110, 160), 0, h, new Color(0, 20, 55)));
                g2.fillRect(0, 0, w, h);
                g2.setColor(new Color(0, 255, 255, 150));
                g2.fillOval(10, 40, 4, 4); g2.fillOval(35, 30, 3, 3);
                g2.fillOval(20, 55, 5, 5);
                g2.setColor(new Color(255, 130, 0));
                g2.fillArc(w/2 - 12, h - 20, 24, 10, 0, -180);
            } else if (title.toLowerCase().contains("dark knight")) {
                g2.setPaint(new GradientPaint(0, 0, new Color(20, 30, 40), w, h, Color.BLACK));
                g2.fillRect(0, 0, w, h);
                g2.setColor(new Color(255, 200, 0, 180));
                g2.fillOval(w/2 - 15, h/2 - 10, 30, 20);
                g2.setColor(Color.BLACK);
                g2.fillOval(w/2 - 19, h/2 - 18, 12, 16);
                g2.fillOval(w/2 + 7, h/2 - 18, 12, 16);
            } else if (title.toLowerCase().contains("avatar")) {
                g2.setPaint(new GradientPaint(0, 0, new Color(0, 191, 255), w, h, new Color(0, 0, 128)));
                g2.fillRect(0, 0, w, h);
                g2.setColor(Color.WHITE);
                g2.drawOval(w/2 - 15, h/2 - 15, 30, 30);
            } else if (title.toLowerCase().contains("star wars")) {
                g2.setColor(Color.BLACK);
                g2.fillRect(0, 0, w, h);
                g2.setColor(Color.CYAN);
                g2.setStroke(new BasicStroke(3));
                g2.drawLine(w/2, 5, w/2, h - 15);
            } else if (title.toLowerCase().contains("avengers")) {
                g2.setPaint(new GradientPaint(0, 0, new Color(139, 0, 0), w, h, new Color(25, 25, 112)));
                g2.fillRect(0, 0, w, h);
                g2.setColor(Color.WHITE);
                g2.drawString("A", w/2 - 4, h/2 + 5);
            } else if (title.toLowerCase().contains("blade runner")) {
                g2.setPaint(new GradientPaint(0, 0, new Color(255, 20, 147), w, h, new Color(75, 0, 130)));
                g2.fillRect(0, 0, w, h);
                g2.setColor(Color.CYAN);
                g2.drawLine(0, h/2, w, h/2);
            } else if (title.toLowerCase().contains("dunkirk")) {
                g2.setPaint(new GradientPaint(0, 0, new Color(100, 115, 130), 0, h, new Color(20, 30, 40)));
                g2.fillRect(0, 0, w, h);
                g2.setColor(Color.WHITE);
                g2.drawLine(0, h - 20, w, h - 20);
            } else if (title.toLowerCase().contains("inception")) {
                g2.setPaint(new GradientPaint(0, 0, new Color(60, 60, 80), 0, h, new Color(10, 10, 20)));
                g2.fillRect(0, 0, w, h);
                g2.setColor(Main.AppTheme.getAccent());
                g2.draw(new Arc2D.Float(w/2-15, h/2-15, 30, 30, 45, 270, Arc2D.OPEN));
            } else if (title.toLowerCase().contains("jaguar")) {
                g2.setPaint(new GradientPaint(0, 0, new Color(200, 140, 20), 0, h, new Color(30, 20, 5)));
                g2.fillRect(0, 0, w, h);
                g2.setColor(Color.BLACK);
                g2.fillOval(w/2 - 15, h/2 - 15, 30, 30);
            } else if (title.toLowerCase().contains("bayan ko")) {
                g2.setPaint(new GradientPaint(0, 0, new Color(180, 20, 30), 0, h, Color.BLACK));
                g2.fillRect(0, 0, w, h);
                g2.setColor(Color.WHITE);
                g2.drawLine(10, h/2, w-10, h/2);
            } else if (title.toLowerCase().contains("brokeback")) {
                g2.setPaint(new GradientPaint(0, 0, new Color(34, 139, 34), 0, h, new Color(20, 40, 20)));
                g2.fillRect(0, 0, w, h);
                g2.setColor(Color.WHITE);
                g2.fillOval(w/2-10, h/2-25, 20, 20);
            } else {
                g2.setPaint(new GradientPaint(0, 0, new Color(100, 50, 150), w, h, new Color(30, 20, 60)));
                g2.fillRect(0, 0, w, h);
                g2.setColor(new Color(255, 255, 255, 60));
                g2.drawRect(5, 5, w - 10, h - 10);
            }


            g2.setColor(Main.AppTheme.getBorderGlass());
            g2.setStroke(new BasicStroke(1));
            g2.drawRoundRect(0, 0, w - 1, h - 1, 14, 14);
        }
    }


    // --- POSTER INTERACTIVE PREVIEW DIALOG ---
    public static class PosterPreviewDialog extends JDialog {
        public PosterPreviewDialog(Frame owner, String movieTitle, String sensoryNotes) {
            super(owner, "Film Poster View - " + movieTitle, true);
            setSize(320, 480);
            setLocationRelativeTo(owner);
            setResizable(false);


            JPanel root = new JPanel(new BorderLayout());
            root.setBackground(new Color(11, 15, 26));
            root.setBorder(new EmptyBorder(20, 20, 20, 20));


            JPanel artContainer = new JPanel() {
                @Override
                protected void paintComponent(Graphics g) {
                    super.paintComponent(g);
                    Graphics2D g2 = (Graphics2D) g.create();
                    g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);


                    String cleanName = movieTitle.toLowerCase()
                            .replaceAll(":", "")
                            .replaceAll("&", "and")
                            .replaceAll("[^a-z0-9]", "_")
                            .replaceAll("__+", "_");
                    String filePath = "images/" + cleanName + ".jpg";
                    ImageIcon scaledIcon = Main.getScaledImage(filePath, getWidth(), getHeight());


                    if (scaledIcon != null) {
                        g2.drawImage(scaledIcon.getImage(), 0, 0, this);
                        g2.setColor(Main.AppTheme.getBorderGlass());
                        g2.drawRoundRect(0, 0, getWidth() - 1, getHeight() - 1, 14, 14);
                    } else {
                        Main.PosterArt.paint(g2, getWidth(), getHeight(), movieTitle);
                    }
                    g2.dispose();
                }
            };
            artContainer.setPreferredSize(new Dimension(180, 260));


            JPanel content = new JPanel();
            content.setLayout(new BoxLayout(content, BoxLayout.Y_AXIS));
            content.setOpaque(false);


            JLabel titleLbl = new JLabel("<html><center><b>" + movieTitle.toUpperCase() + "</b></center></html>", JLabel.CENTER);
            titleLbl.setForeground(Color.WHITE);
            titleLbl.setFont(Main.AppTheme.getFont(Font.BOLD, 14));
            titleLbl.setAlignmentX(Component.CENTER_ALIGNMENT);


            JTextArea notesArea = new JTextArea(sensoryNotes); // Fixed duplicate notesArea constructor typo
            notesArea.setFont(Main.AppTheme.getFont(Font.PLAIN, 12));
            notesArea.setForeground(Color.LIGHT_GRAY);
            notesArea.setLineWrap(true);
            notesArea.setWrapStyleWord(true);
            notesArea.setEditable(false);
            notesArea.setOpaque(false);
            notesArea.setBorder(new EmptyBorder(10, 0, 10, 0));


            Main.ModernButton closeBtn = new Main.ModernButton("DISMISS", Main.AppTheme.getAccent());
            closeBtn.setPreferredSize(new Dimension(280, 40));
            closeBtn.addActionListener(e -> dispose());


            content.add(titleLbl);
            content.add(Box.createRigidArea(new Dimension(0, 10)));
            content.add(notesArea);


            root.add(artContainer, BorderLayout.CENTER);
            root.add(content, BorderLayout.SOUTH);


            setContentPane(root);
        }
    }


    // --- MINI VISUAL SEAT MAP COMPONENT ---
    public static class VisualMiniSeatMap extends JPanel {
        private final List<String> userSeats;


        public VisualMiniSeatMap(List<String> seats) {
            this.userSeats = (seats != null) ? seats : new ArrayList<>();
            setPreferredSize(new Dimension(160, 120));
            setOpaque(false);
        }


        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2 = (Graphics2D) g.create();
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);


            int rows = 6;
            int cols = 6;
            int rectW = 14;
            int rectH = 12;
            int gap = 4;


            int startX = (getWidth() - (cols * (rectW + gap) - gap)) / 2;
            int startY = (getHeight() - (rows * (rectH + gap) - gap)) / 2;


            for (int r = 0; r < rows; r++) {
                for (int c = 0; c < cols; c++) {
                    int index = r * cols + c + 1;
                    String seatId = "S" + index;


                    int x = startX + c * (rectW + gap);
                    int y = startY + r * (rectH + gap);


                    if (userSeats.contains(seatId)) {
                        g2.setColor(Main.AppTheme.getAccent());
                        g2.fillRoundRect(x, y, rectW, rectH, 4, 4);
                        g2.setColor(Color.WHITE);
                        g2.setFont(new Font("SansSerif", Font.BOLD, 6));
                        g2.drawString(seatId, x + 1, y + 8);
                    } else {
                        g2.setColor(new Color(255, 255, 255, 40));
                        g2.drawRoundRect(x, y, rectW, rectH, 4, 4);
                    }
                }
            }
            g2.dispose();
        }
    }


    // --- MINIMALIST ANIMATED FILM STRIP FRAME ---
    public static class MinimalistMovieFrame extends JPanel {
        private int offsetX = 0;


        public MinimalistMovieFrame() {
            setPreferredSize(new Dimension(400, 60));
            setOpaque(false);


            javax.swing.Timer timer = new javax.swing.Timer(35, e -> {
                offsetX -= 2;
                if (offsetX <= -80) {
                    offsetX = 0;
                }
                repaint();
            });
            timer.start();
        }


        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2 = (Graphics2D) g.create();
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);


            int h = getHeight();
            int w = getWidth();


            g2.setColor(new Color(15, 23, 42, 180));
            g2.fillRoundRect(0, 5, w, h - 10, 10, 10);
            g2.setColor(Main.AppTheme.getBorderGlass());
            g2.setStroke(new BasicStroke(1.2f));
            g2.drawRoundRect(0, 5, w - 1, h - 11, 10, 10);


            int cellSize = 65;
            int gap = 15;
            int startX = offsetX;


            while (startX < w + cellSize) {
                g2.setColor(new Color(255, 255, 255, 15));
                g2.fillRect(startX, 12, cellSize, h - 24);
                g2.setColor(Main.AppTheme.getBorderGlass());
                g2.drawRect(startX, 12, cellSize, h - 24);


                g2.setColor(Main.AppTheme.getGold());
                g2.fillOval(startX + cellSize / 2 - 3, h / 2 - 3, 6, 6);


                g2.setColor(Color.BLACK);
                for (int sx = startX + 4; sx < startX + cellSize; sx += 12) {
                    g2.fillRect(sx, 7, 6, 4);
                    g2.fillRect(sx, h - 11, 6, 4);
                }


                startX += cellSize + gap;
            }
            g2.dispose();
        }
    }


    // --- ANIMATED CINEMA PROJECTOR PANEL ---
    public static class AnimatedProjectorCanvas extends JPanel {
        private double rotationAngle = 0;
        private double glowIntensity = 1.0;
        private boolean glowFading = true;


        public AnimatedProjectorCanvas() {
            setPreferredSize(new Dimension(400, 140));
            setOpaque(false);


            javax.swing.Timer animTimer = new javax.swing.Timer(30, e -> {
                rotationAngle += 4.0;
                if (rotationAngle >= 360) rotationAngle = 0;


                if (glowFading) {
                    glowIntensity -= 0.02;
                    if (glowIntensity <= 0.4) glowFading = false;
                } else {
                    glowIntensity += 0.02;
                    if (glowIntensity >= 1.0) glowFading = true;
                }
                repaint();
            });
            animTimer.start();
        }


        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2 = (Graphics2D) g.create();
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);


            int cx = getWidth() / 2;
            int cy = 90;


            int beamY = cy - 10;
            int beamHeight = 85;
            int beamWidth = (int) (180 * glowIntensity);
            int[] px = {cx, cx - beamWidth / 2, cx + beamWidth / 2};
            int[] py = {beamY, beamY - beamHeight, beamY - beamHeight};


            Color beamColor = Main.AppTheme.sensorySafeMode
                    ? new Color(110, 160, 210, (int) (30 * glowIntensity))
                    : new Color(255, 0, 120, (int) (40 * glowIntensity));
            g2.setColor(beamColor);
            g2.fillPolygon(px, py, 3);


            g2.setColor(new Color(25, 30, 41));
            g2.fillRoundRect(cx - 25, cy - 15, 50, 30, 8, 8);
            g2.setColor(Color.DARK_GRAY);
            g2.fillRect(cx - 15, cy - 23, 30, 8);


            g2.setColor(new Color(40, 45, 55));
            int rx1 = cx - 20;
            int ry1 = cy - 35;
            g2.fillOval(rx1 - 18, ry1 - 18, 36, 36);


            g2.setColor(Color.LIGHT_GRAY);
            g2.setStroke(new BasicStroke(2f));
            double rad = Math.toRadians(rotationAngle);
            g2.drawLine(rx1, ry1, (int)(rx1 + 16 * Math.cos(rad)), (int)(ry1 + 16 * Math.sin(rad)));
            g2.drawLine(rx1, ry1, (int)(rx1 - 16 * Math.cos(rad)), (int)(ry1 - 16 * Math.sin(rad)));
            g2.drawLine(rx1, ry1, (int)(rx1 + 16 * Math.sin(rad)), (int)(ry1 - 16 * Math.cos(rad)));


            int rx2 = cx + 20;
            int ry2 = cy - 35;
            g2.setColor(new Color(40, 45, 55));
            g2.fillOval(rx2 - 18, ry2 - 18, 36, 36);


            g2.setStroke(new BasicStroke(2f));
            double radOpp = Math.toRadians(-rotationAngle);
            g2.drawLine(rx2, ry2, (int)(rx2 + 16 * Math.cos(radOpp)), (int)(ry2 + 16 * Math.sin(radOpp)));
            g2.drawLine(rx2, ry2, (int)(rx2 - 16 * Math.cos(radOpp)), (int)(ry2 - 16 * Math.sin(radOpp)));
            g2.drawLine(rx2, ry2, (int)(rx2 + 16 * Math.sin(radOpp)), (int)(ry2 - 16 * Math.cos(radOpp)));


            g2.setColor(Color.LIGHT_GRAY);
            g2.drawOval(cx - 5, cy - 5, 10, 10);


            g2.dispose();
        }
    }


    // --- ANIMATED CINEMA PROJECTOR REEL CANVAS (SENSORY ENGAGEMENT WAVE) ---
    public static class AmbientCinemaReelCanvas extends JPanel {
        private double angle = 0;
        private final List<Point2D.Float> dustParticles = new ArrayList<>();


        public AmbientCinemaReelCanvas() {
            setPreferredSize(new Dimension(400, 100));
            setOpaque(false);


            Random rand = new Random();
            for (int i = 0; i < 15; i++) {
                dustParticles.add(new Point2D.Float(rand.nextFloat() * 400, rand.nextFloat() * 100));
            }


            javax.swing.Timer timer = new javax.swing.Timer(30, e -> {
                angle += 2.0;
                if (angle >= 360) angle = 0;


                for (Point2D.Float p : dustParticles) {
                    p.y -= 0.5f;
                    if (p.y < 0) {
                        p.y = 100;
                        p.x = rand.nextFloat() * getWidth();
                    }
                }
                repaint();
            });
            timer.start();
        }


        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2 = (Graphics2D) g.create();
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);


            int w = getWidth();
            int h = getHeight();


            int sourceX = 60;
            int sourceY = h / 2;
            Path2D.Float beam = new Path2D.Float();
            beam.moveTo(sourceX, sourceY);
            beam.lineTo(w, sourceY - 40);
            beam.lineTo(w, sourceY + 40);
            beam.closePath();


            Color accentColor = Main.AppTheme.getAccent();
            Color beamColor = new Color(accentColor.getRed(), accentColor.getGreen(), accentColor.getBlue(), 35);
            g2.setPaint(new GradientPaint(sourceX, sourceY, beamColor, w, sourceY, new Color(0, 0, 0, 0)));
            g2.fill(beam);


            g2.setColor(new Color(255, 255, 255, 40));
            g2.setStroke(new BasicStroke(1.5f));
            drawReel(g2, sourceX, sourceY, 28, angle);
            drawReel(g2, sourceX + 45, sourceY, 22, -angle * 1.2);


            g2.setColor(new Color(255, 255, 255, 60));
            g2.drawLine(sourceX, sourceY - 28, sourceX + 45, sourceY - 22);
            g2.drawLine(sourceX, sourceY + 28, sourceX + 45, sourceY + 22);


            g2.setColor(new Color(255, 255, 255, 120));
            for (Point2D.Float p : dustParticles) {
                float px = p.x;
                if (px > w) px = px % w;
                g2.fill(new Ellipse2D.Float(px, p.y, 2, 2));
            }


            g2.dispose();
        }


        private void drawReel(Graphics2D g2, int cx, int cy, int radius, double rot) {
            g2.drawOval(cx - radius, cy - radius, radius * 2, radius * 2);
            g2.drawOval(cx - 5, cy - 5, 10, 10);
            for (int i = 0; i < 5; i++) {
                double spokeAngle = Math.toRadians(rot + i * (360.0 / 5.0));
                int sx = (int) (cx + radius * Math.cos(spokeAngle));
                int sy = (int) (cy + radius * Math.sin(spokeAngle));
                g2.drawLine(cx, cy, sx, sy);
            }
        }
    }


    // --- CORE DATA MODELS ---
    public static class User {
        private String username;
        private String password;
        private String fullName = "";
        private String email = "";
        private String phone = "";
        private String country = "Philippines";


        public User(String username, String password) {
            this.username = username;
            this.password = password;
        }
    }


    public static class Movie {
        private String title;
        private String genre;
        private String releaseEra;
        private String exactDate;
        private String director;
        private String sensoryProfile;
        private boolean isSensorySafe;
        private double basePriceUSD;


        public Movie(String title, String genre, String era, String date, String director, String profile, boolean isSafe, double priceUSD) {
            this.title = title;
            this.genre = genre;
            this.releaseEra = era;
            this.exactDate = date;
            this.director = director;
            this.sensoryProfile = profile;
            this.isSensorySafe = isSafe;
            this.basePriceUSD = priceUSD;
        }


        public double getPriceInCurrency(String country) {
            if ("Taiwan".equalsIgnoreCase(country)) {
                return basePriceUSD * 32.0;
            } else {
                return basePriceUSD * 56.0;
            }
        }


        public String getCurrencySymbol(String country) {
            return "Taiwan".equalsIgnoreCase(country) ? "NT$" : "₱";
        }
    }


    public static class Booking {
        private Movie movie;
        private String userEmail = "";
        private String tier = "Individual Booking";
        private String selectedVenue = "";
        private String selectedDate = "";
        private String selectedTime = "";


        private int adultCount = 1;
        private int childCount = 0;
        private int pwdCount = 0;


        private boolean foodPopcorn = false;
        private boolean foodChamomileTea = false;
        private boolean foodCalmBites = false;


        private String paymentMethod = "Credit/Debit Card";
        private List<String> selectedSeats = new ArrayList<>();
        private double calculatedPrice = 0.0;
        private String referenceCode = "";


        public void calculateFinalPrice(String country) {
            double ratePerTicket = movie.getPriceInCurrency(country);
            double total = 0;


            total += adultCount * ratePerTicket;
            total += childCount * (ratePerTicket * 0.70);
            total += pwdCount * (ratePerTicket * 0.60);


            double currencyFactor = "Taiwan".equalsIgnoreCase(country) ? 32.0 : 56.0;
            if (foodPopcorn) total += 3.0 * currencyFactor;
            if (foodChamomileTea) total += 2.5 * currencyFactor;
            if (foodCalmBites) total += 3.5 * currencyFactor;


            calculatedPrice = total;
        }
    }


    // --- COMPACT ARCHIVE REGISTRY ---
    public static class DirectorArchive {
        public static final String[] DIRECTORS = {
                "CHRISTOPHER NOLAN", "LINO BROCKA", "ANG LEE"
        };
        public static final String[] BIOS = {
                "Christopher Nolan is a highly celebrated British-American filmmaker renowned for his mind-bending narratives, non-linear timelines, and dedication to practical visual effects. Over a stellar three-decade career, his critically acclaimed films have grossed over five billion dollars globally, earning him multiple Academy Awards and cementing his influence in cinematic history. He represents a rare breed of commercial auteur who maintains absolute creative control over monumental studio blockbusters.<br><br>He consistently explores complex philosophical concepts including the manipulation of time, the fragility of memory, and the intricate architecture of human dreams. His refusal to rely heavily on green screens or computer-generated imagery ensures that each film delivers a deeply visceral, authentic, and emotionally striking experience. By prioritizing physical, in-camera film mechanics, Nolan continues to challenge and redefine the boundaries of modern storytelling.",
                "Lino Brocka stands as one of the most influential Filipino directors of all time, widely revered for his courageous social realism and passionate political activism during the Second Golden Age of Philippine Cinema. Operating under a highly restrictive political regime, he bravely utilized his films to shine a light on the raw struggles of marginalized urban communities. He single-handedly elevated Southeast Asian cinema onto the global festival circuit with his unflinching gaze.<br><br>His legendary masterworks, such as \"Manila in the Claws of Light\" and \"Jaguar,\" introduced the world to the depth of Southeast Asian storytelling and secured his legacy as a cinematic pioneer. Beyond his creative vision behind the lens, Brocka was a dedicated champion of free expression and human rights, demonstrating how cinema can serve as a catalyst for genuine societal change. His artistic legacy remains an enduring blueprint for socially conscious artists worldwide.",
                "Ang Lee is a master Taiwanese filmmaker celebrated globally for his extraordinary versatility, deep emotional sensitivity, and unique ability to bridge Eastern and Western cultures. He is one of the few directors in history to win multiple Academy Awards for Best Director, proving his exceptional cross-cultural appeal and technical mastery. His films frequently depict the quiet struggles of individuals caught between societal traditions and deep personal desires.<br><br>His rich filmography seamlessly spans multiple diverse genres, ranging from poetic martial arts epics to breathtaking philosophical adventures that test the limits of human survival. By constantly pioneering advanced visual technologies, such as high frame rates and 3D space, Lee creates immersive cinematic environments that profoundly touch the human soul. His dedication to emotional honesty and technical innovation makes him a true pioneer of modern world cinema."
        };
    }


